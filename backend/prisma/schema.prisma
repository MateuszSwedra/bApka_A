generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CARETAKER
  DEPENDENT
  HYBRID
}

enum LogStatus {
  TAKEN
  LATE
  MISSED
  PENDING
}

enum LogSource {
  APP_SENIOR
  APP_CARETAKER
  SYSTEM_AUTO
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?  
  role      Role
  fcmToken  String?
  name      String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastMood    String?
  lastMoodAt  DateTime?
  moodEnabled Boolean @default(true)

  // Relacje połączeń (opiekun <-> podopieczny)
  caretakerConnections Connection[] @relation("CaretakerConnections")
  dependentConnections Connection[] @relation("DependentConnections")

  // Relacje do harmonogramów
  schedules         Schedule[] @relation("OwnedSchedules")   // Harmonogramy przypisane do tego użytkownika (Seniora)
  createdSchedules  Schedule[] @relation("CreatedSchedules") // Harmonogramy utworzone przez tego użytkownika (Opiekuna)
  
  inventory Inventory[]
  moodLogs  MoodLog[]
  sosLogs   SosLog[]
  healthMetricLogs HealthMetricLog[]
}

model Connection {
  id           String   @id @default(uuid())
  caretakerId  String
  dependentId  String?
  pin          String?  @unique
  isPaired     Boolean  @default(false)
  createdAt    DateTime @default(now())

  caretaker User @relation("CaretakerConnections", fields: [caretakerId], references: [id])
  dependent User? @relation("DependentConnections", fields: [dependentId], references: [id])
}

model Inventory {
  id              String   @id @default(uuid())
  userId          String
  name            String
  type            String   @default("MEDICATION")
  description     String?
  totalPills      Int?
  currentPills    Int?
  pillsPerDose    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  schedules Schedule[]
}

model Schedule {
  id          String   @id @default(uuid())
  userId      String   // ID Seniora (do kogo należy ten lek)
  createdById String?  // ID Opiekuna (kto dodał/podyktował ten lek)
  inventoryId String?
  medication  String?
  dosage      String
  time        String   // np. "08:30"
  type        String   @default("DAILY")
  startDate   String?  
  endDate     String?
  daysOfWeek  Int[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation("OwnedSchedules", fields: [userId], references: [id])
  creator   User?      @relation("CreatedSchedules", fields: [createdById], references: [id])
  inventory Inventory? @relation(fields: [inventoryId], references: [id])
  logs      DoseLog[]
}

model DoseLog {
  id          String    @id @default(uuid())
  scheduleId  String
  status      LogStatus @default(PENDING)
  source      LogSource? 
  scheduledAt DateTime
  takenAt     DateTime?
  createdAt   DateTime  @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id])
}

model MoodLog {
  id        String   @id @default(uuid())
  userId    String
  mood      String
  source    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SosLog {
  id        String   @id @default(uuid())
  userId    String
  source    String?
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model HealthMetricLog {
  id         String   @id @default(uuid())
  userId     String
  type       String
  value      Float?
  systolic   Int?
  diastolic  Int?
  pulse      Int?
  unit       String?
  measuredAt DateTime
  source     String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}