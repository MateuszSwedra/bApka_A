DATABASE_URL=
JWT_SECRET=

# Strefa harmonogramów leków (HH:mm w aplikacji) — domyślnie Europe/Warsaw
APP_TIMEZONE=Europe/Warsaw

# Te same wartości co w frontend/.env (Google Cloud Console):
GOOGLE_CLIENT_ID=
# Firebase Admin (alarm SOS) — skopiuj plik *-firebase-adminsdk*.json jako:
# backend/firebase-service-account.json  (NIE commituj)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Alternatywa (tylko lokalnie, jedna linia): FIREBASE_SERVICE_ACCOUNT_JSON=
