# Skopiuj do .env i uzupełnij po konfiguracji Google Cloud (patrz: npm run google:setup)

# Web (przeglądarka) - wystarczy sam Web client ID:
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Android (APK) - dodatkowo Android client ID:
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Google Cloud → Web client → Authorized JavaScript origins (dev):
#   http://localhost:8081
#   http://127.0.0.1:8081
# Authorized redirect URIs - dodaj dokładny URL z konsoli po starcie web
# (zwykle http://localhost:8081 lub http://localhost:8081/login)

# Wstawiane automatycznie przez: npx eas init
# EXPO_PUBLIC_EAS_PROJECT_ID=

# Dev: podgląd panelu seniora bez backendu - wymaga przycisku na ekranie logowania
# EXPO_PUBLIC_DEV_SENIOR_PREVIEW=true

# Adres API (dev client na telefonie - IP komputera z Dockerem):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3000
